<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="FullAPISuite">

    <!-- Test 1: Run entire package -->
    <test name="HelloWorldTests">
        <packages>
            <package name="com.SekharSVB.ex_01_RestAssured_HelloWorld"/>
        </packages>
    </test>

    <!-- Test 2: Run specific classes and methods -->
    <test name="BasicAPITests">
        <classes>

            <class name="com.SekharSVB.ex_02_RestAssured_Basic.APITesting_Lab05_Multiple_TestCase">
                <methods>
                    <include name="test_Positive_tc1"/>
                    <include name="test_Negative_tc1"/>
                </methods>
            </class>

            <class name="com.SekharSVB.ex_02_RestAssured_Basic.APITesting_Lab04_BuilderPattern"/>

        </classes>
    </test>

</suite>